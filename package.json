{
  "name": "yolo-ai-reviewer",
  "version": "1.0.0",
  "description": "Automated AI code review for GitLab & GitHub — multi-platform, zero infrastructure required.",
  "module": "src/index.ts",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/akhfasarrofi/yolo-reviewer"
  },
  "bin": {
    "yolo": "./dist/cli/index.js",
    "yolo-run": "./dist/cli/run.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "run:ci": "bun run src/cli/run.ts",
    "build": "bun build src/cli/index.ts src/cli/run.ts --outdir dist/cli --target node --format esm && bun build src/index.ts --outdir dist --target node --format esm",
    "prepublishOnly": "bun run build",
    "release": "bun scripts/release.ts",
    "typecheck": "tsc --noEmit",
    "format": "biome check --write",
    "prepare": "husky",
    "validate": "bun typecheck && bun format"
  },
  "dependencies": {
    "hono": "^4.12.17",
    "js-yaml": "^4.1.1",
    "octokit": "^5.0.5",
    "prompts": "^2.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@types/bun": "^1.3.13",
    "@types/js-yaml": "^4.0.9",
    "@types/prompts": "^2.4.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --write"
    ]
  }
}
