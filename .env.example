# ============================================================
# Yolo AI Reviewer — Environment Variables
# Copy this file to .env and fill in your credentials.
# ============================================================

# ─────────────────────────────────────────
# GitLab Platform (required if using GitLab)
# ─────────────────────────────────────────
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
GITLAB_WEBHOOK_SECRET=your-webhook-secret

# ─────────────────────────────────────────
# GitHub Platform (required if using GitHub)
# ─────────────────────────────────────────
# Option 1: Personal Access Token
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Option 2: GitHub App (recommended for professional setup)
# GITHUB_APP_ID=123456
# GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
# GITHUB_API_URL=https://api.github.com  # optional: override for GHES

GITHUB_WEBHOOK_SECRET=your-webhook-secret

# ─────────────────────────────────────────
# AI Provider (required)
# Must be an OpenAI-compatible endpoint (/v1/chat/completions)
# ─────────────────────────────────────────
AI_BASE_URL=https://api.openai.com
AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
AI_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.1
AI_TOP_P=1.0

# ─────────────────────────────────────────
# Server
# ─────────────────────────────────────────
PORT=3000

# ─────────────────────────────────────────
# Telegram Notifications (optional)
# Used in CI/CD mode. In Server/Docker mode, configure via config.yml instead.
# ─────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=123456789:xxxxxxxxxxxxxxxxxxxx
# TELEGRAM_CHAT_ID=-100123456789
# TELEGRAM_TRIGGER_CATEGORIES=security,critical
